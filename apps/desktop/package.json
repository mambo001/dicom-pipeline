{
  "name": "@dicom-pipeline/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dicom-pipeline/contracts": "0.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2"
  }
}
