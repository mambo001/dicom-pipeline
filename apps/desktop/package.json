{
  "name": "@dicom-pipeline/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run dev:renderer",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:8080 http://127.0.0.1:5173 dist/main/main.js dist/preload/preload.js && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build --workspace @dicom-pipeline/contracts && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run --passWithNoTests",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.dicom-pipeline.prototype",
    "productName": "DICOM Pipeline",
    "directories": {
      "output": "release"
    },
    "electronVersion": "35.7.5",
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.medical",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@dicom-pipeline/contracts": "0.1.0"
  },
  "devDependencies": {
    "@cornerstonejs/core": "^4.22.8",
    "@cornerstonejs/dicom-image-loader": "^4.22.8",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "date-fns": "^4.1.0",
    "dicom-parser": "^1.8.21",
    "effect": "^3.21.2",
    "electron": "35.7.5",
    "electron-builder": "^26.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.2",
    "zustand": "^5.0.13"
  }
}